---
import { getCategoryColor } from '../data/tools';

interface Props {
  name: string;
  description: string;
  url: string;
  icon: string;
  category: string;
}

const { name, description, url, icon, category } = Astro.props;
const catColor = getCategoryColor(category);
---

<a href={url} class="tool-grid-card" style={`--cat-color: ${catColor};`}>
  <div class="tool-icon-wrapper" style={`background-color: color-mix(in srgb, ${catColor} 12%, transparent); border-color: color-mix(in srgb, ${catColor} 18%, transparent); color: ${catColor};`}>
    <i class={`ph ${icon}`} style="font-size: 22px;"></i>
  </div>
  <h3>{name}</h3>
  <p>{description}</p>
  <div class="tool-meta-wrapper">
    <span class="tool-badge" style={`color: ${catColor}; border-color: color-mix(in srgb, ${catColor} 20%, transparent); background: color-mix(in srgb, ${catColor} 8%, transparent);`}>{category}</span>
  </div>
</a>
