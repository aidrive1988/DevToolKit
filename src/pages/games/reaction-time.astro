---
import GameLayout from '../../layouts/GameLayout.astro';
---

<GameLayout title="Reaction Time — Premium Edition" description="Test your visual reflexes with this high-stakes dashboard." gameName="Reaction Time" category="Speed">
  
  <div class="game-container">
    
    <!-- Top Dashboard -->
    <div class="game-stats">
      <div class="stat-box">
        <span class="stat-label">Session Average</span>
        <span class="stat-value"><span id="avg-time">--</span> <span class="stat-unit">ms</span></span>
      </div>
      <div class="stat-box">
        <span class="stat-label">Overall Best</span>
        <span class="stat-value"><span id="best-time">--</span> <span class="stat-unit">ms</span></span>
        <div class="new-record-badge" id="new-record-badge" style="display: none;">NEW BEST</div>
      </div>
    </div>

    <!-- The actual clickable area -->
    <div id="reaction-area" class="reaction-area state-idle">
      
      <div class="radar-circle" id="radar-circle"></div>
      
      <div class="content-z-index">
        <div class="reaction-icon" id="icon-container">
          <i class="ph ph-lightning" id="reaction-icon-ph"></i>
        </div>
        <h2 id="reaction-text">Click anywhere to start</h2>
        <p id="reaction-subtext">Session: 5 attempts</p>
      </div>
      
    </div>
    
    <!-- Bottom Attempt History -->
    <div class="attempts-container glass-panel">
      <h3 style="font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem;">Current Session</h3>
      <div class="attempts-grid">
        <div class="attempt-box" id="attempt-0">---</div>
        <div class="attempt-box" id="attempt-1">---</div>
        <div class="attempt-box" id="attempt-2">---</div>
        <div class="attempt-box" id="attempt-3">---</div>
        <div class="attempt-box" id="attempt-4">---</div>
      </div>
      
      <button class="btn btn-primary" id="btn-restart" style="display: none; margin-top: 2rem; width: 100%;">Start New Session</button>
    </div>
    
  </div>

  <!-- How to Play Section -->
  <div class="glass-panel" style="max-width: 800px; width: 100%; margin: 2rem auto; padding: 2rem;">
    <h3 style="margin-bottom: 1rem; color: var(--accent-purple);">How to Play</h3>
    <ul style="list-style-type: disc; margin-left: 2rem; color: var(--text-secondary); display: flex; flex-direction: column; gap: 0.5rem; font-size: 1.4rem;">
      <li>Click the large area above to start the test. The radar will turn <strong style="color: var(--cat-media);">Red</strong> and begin pulsing.</li>
      <li>Wait for the radar to instantly turn <strong style="color: var(--cat-developer);">Green</strong>.</li>
      <li>As soon as it turns green, click as fast as you can!</li>
      <li>Clicking too early results in a penalty try. Complete 5 attempts to get your session average.</li>
    </ul>
  </div>

  <style is:global>
    .game-container {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    
    .game-stats {
      display: flex;
      justify-content: space-between;
      gap: 1.5rem;
    }
    
    .stat-box {
      background: var(--bg-card);
      padding: 1.5rem 2rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
      box-shadow: 0 0 20px rgba(168, 85, 247, 0.05), var(--shadow-sm);
      position: relative;
      overflow: hidden;
    }
    
    .new-record-badge {
      position: absolute;
      top: 0;
      width: 100%;
      background: var(--cat-developer);
      color: #000;
      font-size: 1rem;
      font-weight: 800;
      text-transform: uppercase;
      text-align: center;
      padding: 0.2rem;
      animation: slide-down 300ms ease-out;
    }
    
    @keyframes slide-down {
      from { transform: translateY(-100%); }
      to { transform: translateY(0); }
    }
    
    .stat-label {
      font-size: 1.2rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 600;
    }
    
    .stat-value {
      font-size: 2.8rem;
      font-family: var(--font-display);
      font-weight: 700;
      color: var(--text-primary);
      display: flex;
      align-items: baseline;
      gap: 0.4rem;
    }
    
    .stat-unit {
      font-size: 1.4rem; 
      color: var(--text-muted);
    }
    
    .reaction-area {
      width: 100%;
      height: 400px;
      border-radius: var(--radius-lg);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      cursor: pointer;
      user-select: none;
      transition: background-color 0.1s, transform 0.1s, box-shadow 0.15s, border-color 0.15s;
      position: relative;
      overflow: hidden;
      border: 2px solid transparent;
    }
    
    .reaction-area:active {
      transform: scale(0.98);
    }
    
    .content-z-index {
      position: relative;
      z-index: 10;
    }
    
    .radar-circle {
      position: absolute;
      width: 150px;
      height: 150px;
      border-radius: 50%;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      opacity: 0;
      z-index: 1;
    }
    
    .reaction-icon {
      font-size: 6rem;
      margin-bottom: 1.5rem;
      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    .reaction-area h2 {
      font-size: 3.2rem;
      margin-bottom: 1rem;
      font-weight: 700;
    }
    
    .reaction-area p {
      font-size: 1.8rem;
      opacity: 0.8;
    }
    
    /* Premium States */
    .state-idle {
      background: var(--bg-card);
      border-color: var(--border-color);
      color: var(--text-primary);
      box-shadow: 0 0 30px rgba(168, 85, 247, 0.05);
    }
    .state-idle:hover {
      border-color: var(--accent-purple);
      box-shadow: 0 0 30px rgba(168, 85, 247, 0.2);
    }
    
    .state-waiting {
      background: #3f1d24; /* Deep dark red */
      border-color: var(--cat-media);
      color: white;
      box-shadow: 0 0 50px rgba(232, 115, 90, 0.2), inset 0 0 50px rgba(232, 115, 90, 0.1);
    }
    .state-waiting .radar-circle {
      opacity: 1;
      background: rgba(232, 115, 90, 0.2);
      animation: radar-pulse 1.5s infinite ease-out;
    }
    .state-waiting .reaction-icon {
      color: var(--cat-media);
    }
    
    .state-ready {
      background: var(--cat-developer);
      border-color: #ffffff;
      color: #000;
      box-shadow: 0 0 80px rgba(61, 220, 151, 0.5), inset 0 0 50px rgba(255, 255, 255, 0.5);
    }
    .state-ready .radar-circle {
      opacity: 0;
    }
    .state-ready .reaction-icon {
      transform: scale(1.3);
      color: #000;
    }
    
    .state-result {
      background: var(--bg-card-hover);
      border-color: var(--accent-cyan);
      color: var(--text-primary);
      box-shadow: 0 0 30px rgba(34, 211, 238, 0.1);
    }
    .state-result .reaction-icon {
      color: var(--accent-cyan);
    }
    
    .state-done {
      background: var(--bg-card);
      border-color: var(--accent-purple);
      color: var(--text-primary);
      box-shadow: 0 0 30px rgba(168, 85, 247, 0.15);
    }
    .state-done .reaction-icon {
      color: var(--accent-purple);
    }
    
    @keyframes radar-pulse {
      0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0.8; }
      100% { transform: translate(-50%, -50%) scale(3.5); opacity: 0; }
    }
    
    .attempts-container {
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    
    .attempts-grid {
      display: flex;
      gap: 1rem;
      width: 100%;
      justify-content: space-between;
    }
    
    .attempt-box {
      flex: 1;
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-sm);
      padding: 1.2rem 0;
      text-align: center;
      font-family: var(--font-code);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--text-muted);
      transition: all var(--transition-fast);
    }
    
    .attempt-box.filled {
      background: var(--bg-card-hover);
      color: var(--text-primary);
      border-color: var(--accent-cyan);
      box-shadow: 0 0 10px rgba(34, 211, 238, 0.1);
    }
    
    .attempt-box.error {
      background: rgba(232, 115, 90, 0.1);
      color: var(--cat-media);
      border-color: var(--cat-media);
      text-decoration: line-through;
    }
    
    @media (max-width: 600px) {
      .reaction-area { height: 300px; }
      .reaction-area h2 { font-size: 2.4rem; }
      .reaction-icon { font-size: 4rem; }
      .attempts-grid { flex-direction: column; gap: 0.5rem; }
      .attempt-box { padding: 0.8rem 0; }
    }
  </style>

  <script is:inline>
    const area = document.getElementById('reaction-area');
    const icon = document.getElementById('reaction-icon-ph');
    const title = document.getElementById('reaction-text');
    const subtext = document.getElementById('reaction-subtext');
    
    const bestTimeEl = document.getElementById('best-time');
    const avgTimeEl = document.getElementById('avg-time');
    const newRecordBadge = document.getElementById('new-record-badge');
    const btnRestart = document.getElementById('btn-restart');
    
    // Game States: idle, waiting, ready, result, done
    let state = 'idle'; 
    let timeoutId = null;
    let startTime = 0;
    
    const MAX_ATTEMPTS = 5;
    let currentAttempt = 0;
    let sessionTimes = [];
    
    let bestTime = localStorage.getItem('reaction-premium-best') ? parseInt(localStorage.getItem('reaction-premium-best')) : null;
    if (bestTime) bestTimeEl.textContent = bestTime;
    
    function setState(newState) {
      area.classList.remove('state-idle', 'state-waiting', 'state-ready', 'state-result', 'state-done');
      state = newState;
      area.classList.add(`state-${state}`);
      
      switch(state) {
        case 'idle':
          icon.className = 'ph ph-lightning';
          title.textContent = 'Click to start session';
          subtext.textContent = `Attempt 1 of ${MAX_ATTEMPTS}`;
          break;
        case 'waiting':
          icon.className = 'ph ph-radar';
          title.textContent = 'Wait for Green...';
          subtext.textContent = 'Do not click yet!';
          break;
        case 'ready':
          icon.className = 'ph ph-check-circle';
          title.textContent = 'CLICK!';
          subtext.textContent = '';
          break;
        case 'result':
          icon.className = 'ph ph-clock';
          // title updated dynamically
          subtext.textContent = 'Click to continue';
          break;
        case 'done':
          icon.className = 'ph ph-chart-polar';
          title.textContent = 'Session Complete';
          subtext.textContent = 'Check your average below';
          btnRestart.style.display = 'block';
          break;
      }
    }
    
    function startGame() {
      if (currentAttempt >= MAX_ATTEMPTS) return;
      
      setState('waiting');
      const delay = 1500 + Math.random() * 3000;
      
      timeoutId = setTimeout(() => {
        setState('ready');
        startTime = performance.now();
      }, delay);
    }
    
    function handleTooEarly() {
      clearTimeout(timeoutId);
      
      const box = document.getElementById(`attempt-${currentAttempt}`);
      box.textContent = "FAIL";
      box.classList.add('error');
      
      setState('result');
      icon.className = 'ph ph-warning-circle';
      title.textContent = 'Too early!';
      subtext.textContent = 'Penalty attempt. Click to try again.';
      // We don't increment attempt, we just force them to try this one again
      // OR we count it as a fail. Let's make them retry the attempt.
      box.classList.remove('error'); // reset visual for retry
      box.textContent = "---";
    }
    
    function handleSuccess() {
      const endTime = performance.now();
      const reactionTime = Math.round(endTime - startTime);
      
      sessionTimes.push(reactionTime);
      
      // Update UI Box
      const box = document.getElementById(`attempt-${currentAttempt}`);
      box.textContent = `${reactionTime} ms`;
      box.classList.add('filled');
      
      currentAttempt++;
      
      if (currentAttempt >= MAX_ATTEMPTS) {
        finishSession();
      } else {
        setState('result');
        title.textContent = `${reactionTime} ms`;
        subtext.textContent = `Click for attempt ${currentAttempt + 1}`;
      }
    }
    
    function finishSession() {
      const sum = sessionTimes.reduce((a, b) => a + b, 0);
      const avg = Math.round(sum / sessionTimes.length);
      
      avgTimeEl.textContent = avg;
      
      if (!bestTime || avg < bestTime) {
        bestTime = avg;
        localStorage.setItem('reaction-premium-best', bestTime);
        bestTimeEl.textContent = bestTime;
        newRecordBadge.style.display = 'block';
      }
      
      setState('done');
    }
    
    function resetSession() {
      currentAttempt = 0;
      sessionTimes = [];
      newRecordBadge.style.display = 'none';
      avgTimeEl.textContent = "--";
      btnRestart.style.display = 'none';
      
      for(let i=0; i<MAX_ATTEMPTS; i++) {
        const box = document.getElementById(`attempt-${i}`);
        box.textContent = "---";
        box.className = "attempt-box";
      }
      
      setState('idle');
    }
    
    area.addEventListener('mousedown', (e) => {
      e.preventDefault(); 
      handleClick();
    });
    
    area.addEventListener('touchstart', (e) => {
      e.preventDefault();
      handleClick();
    }, {passive: false});
    
    function handleClick() {
      if (state === 'idle' || state === 'result') {
        startGame();
      } else if (state === 'waiting') {
        handleTooEarly();
      } else if (state === 'ready') {
        handleSuccess();
      }
    }
    
    btnRestart.addEventListener('click', resetSession);
  </script>

</GameLayout>
