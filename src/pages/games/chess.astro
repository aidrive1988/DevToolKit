---
import GameLayout from '../../layouts/GameLayout.astro';
---

<GameLayout title="Premium Chess" description="Play chess against a smart AI on a sleek premium board." gameName="Chess" category="Strategy">
  
  <div class="game-container">
    <div class="game-header">
      <div class="stat-box">
        <span class="stat-label">Difficulty</span>
        <select id="difficulty-select" class="diff-select">
          <option value="1">Easy (Random)</option>
          <option value="2" selected>Normal (Depth 2)</option>
          <option value="3">Hard (Depth 3)</option>
          <option value="4">Very Hard (Depth 4)</option>
        </select>
      </div>
      <div class="stat-box">
        <span class="stat-label">Status</span>
        <span class="stat-value" id="game-status">White to move</span>
      </div>
      <button class="btn btn-primary btn-icon" id="btn-restart" style="padding: 1.2rem; align-self: stretch;">
        <i class="ph ph-arrow-counter-clockwise" style="font-size: 2rem;"></i>
      </button>
    </div>

    <!-- 3D Board Wrapper -->
    <div class="board-wrapper">
      <div class="board-container">
        <div class="chess-board" id="chess-board">
          <!-- Squares and pieces injected via JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- How to Play Section -->
  <div class="glass-panel" style="max-width: 800px; width: 100%; margin: 2rem auto; padding: 2rem;">
    <h3 style="margin-bottom: 1rem; color: var(--cat-encoding);">How to Play</h3>
    <ul style="list-style-type: disc; margin-left: 2rem; color: var(--text-secondary); display: flex; flex-direction: column; gap: 0.5rem; font-size: 1.4rem;">
      <li>Select a difficulty level from the dropdown. The AI uses a Minimax algorithm.</li>
      <li>Click a neon-cyan piece to select it, then click a highlighted square to move.</li>
      <li>The board is rendered in a sleek top-down 2D view for maximum speed and readability.</li>
    </ul>
  </div>

  <style is:global>
    .game-container {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 2.4rem;
    }
    
    .game-header {
      display: flex;
      gap: 1.6rem;
      width: 100%;
      align-items: center;
    }
    
    .stat-box {
      background: var(--bg-card);
      padding: 1.2rem 2rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
      box-shadow: 0 0 20px rgba(91, 155, 217, 0.05), var(--shadow-sm);
    }
    
    .stat-label {
      font-size: 1.2rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 600;
    }
    
    .stat-value {
      font-size: 2rem;
      font-family: var(--font-display);
      font-weight: 700;
      color: var(--cat-encoding);
      text-align: center;
    }

    .diff-select {
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.5rem 1rem;
      border-radius: var(--radius-sm);
      font-family: var(--font-display);
      font-size: 1.4rem;
      margin-top: 0.5rem;
      cursor: pointer;
    }
    
    /* 2D Board CSS */
    .board-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2rem;
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-color);
      box-shadow: 0 0 40px rgba(91, 155, 217, 0.1);
      overflow: hidden;
    }
    
    .board-container {
      width: 400px;
      height: 400px;
      position: relative;
    }
    
    .chess-board {
      width: 100%;
      height: 100%;
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      grid-template-rows: repeat(8, 1fr);
      border: 4px solid var(--bg-card-hover);
      border-radius: 4px;
      background: #111;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    
    .square {
      width: 100%;
      height: 100%;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background-color 0.2s;
    }
    
    .sq-light { background: #374151; }
    .sq-dark { background: #1F2937; }
    
    /* Highlight states */
    .square.highlight {
      background: rgba(91, 155, 217, 0.5) !important;
      cursor: pointer;
    }
    
    .square.selected {
      background: rgba(61, 220, 151, 0.6) !important;
    }
    
    /* Pieces */
    .piece {
      font-size: 3.5rem;
      line-height: 1;
      pointer-events: none; /* Let square handle clicks */
      user-select: none;
      filter: drop-shadow(0 4px 4px rgba(0,0,0,0.4));
    }
    
    /* Premium Colors */
    .piece.w {
      color: var(--accent-cyan);
      text-shadow: 0 0 15px rgba(34, 211, 238, 0.4);
    }
    .piece.b {
      color: var(--accent-purple);
      text-shadow: 0 0 15px rgba(168, 85, 247, 0.4);
    }
    
    @media (max-width: 600px) {
      .board-container {
        width: 300px;
        height: 300px;
      }
      .piece {
        font-size: 2.5rem;
      }
      .game-header { flex-wrap: wrap; }
    }
  </style>

  <!-- Load chess.js from unpkg for game rules -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>
  
  <script is:inline>
    const boardEl = document.getElementById('chess-board');
    const statusEl = document.getElementById('game-status');
    const difficultySelect = document.getElementById('difficulty-select');
    const btnRestart = document.getElementById('btn-restart');
    
    let game = new Chess();
    let selectedSquare = null;
    let isPlayerTurn = true;
    
    // Unicode pieces map
    const unicodePieces = {
      p: '♟', n: '♞', b: '♝', r: '♜', q: '♛', k: '♚'
    };
    
    function renderBoard() {
      boardEl.innerHTML = '';
      const board = game.board(); // 8x8 array
      
      for (let r = 0; r < 8; r++) {
        for (let c = 0; c < 8; c++) {
          const squareEl = document.createElement('div');
          const isLight = (r + c) % 2 === 0;
          squareEl.className = `square ${isLight ? 'sq-light' : 'sq-dark'}`;
          
          // chess.js ranks are 8 to 1 (top to bottom), files are a to h
          const file = String.fromCharCode(97 + c);
          const rank = 8 - r;
          const sqName = `${file}${rank}`;
          squareEl.dataset.sq = sqName;
          
          // Draw piece
          const piece = board[r][c];
          if (piece) {
            const pieceEl = document.createElement('div');
            pieceEl.className = `piece ${piece.color}`;
            pieceEl.textContent = unicodePieces[piece.type];
            squareEl.appendChild(pieceEl);
          }
          
          // Interaction
          squareEl.addEventListener('click', () => handleSquareClick(sqName));
          
          boardEl.appendChild(squareEl);
        }
      }
      updateStatus();
    }
    
    function handleSquareClick(sqName) {
      if (!isPlayerTurn || game.game_over()) return;
      
      // Clear highlights
      clearHighlights();
      
      if (selectedSquare) {
        // Attempt move
        const move = game.move({
          from: selectedSquare,
          to: sqName,
          promotion: 'q' // always promote to queen for simplicity
        });
        
        if (move) {
          selectedSquare = null;
          renderBoard();
          isPlayerTurn = false;
          updateStatus();
          setTimeout(makeAIMove, 100);
        } else {
          // Select new piece if it's player's
          const piece = game.get(sqName);
          if (piece && piece.color === 'w') {
            selectedSquare = sqName;
            highlightSquare(sqName);
            highlightLegalMoves(sqName);
          } else {
            selectedSquare = null;
          }
        }
      } else {
        const piece = game.get(sqName);
        if (piece && piece.color === 'w') {
          selectedSquare = sqName;
          highlightSquare(sqName);
          highlightLegalMoves(sqName);
        }
      }
    }
    
    function highlightSquare(sqName) {
      const el = document.querySelector(`[data-sq="${sqName}"]`);
      if (el) el.classList.add('selected');
    }
    
    function highlightLegalMoves(sqName) {
      const moves = game.moves({ square: sqName, verbose: true });
      moves.forEach(m => {
        const el = document.querySelector(`[data-sq="${m.to}"]`);
        if (el) el.classList.add('highlight');
      });
    }
    
    function clearHighlights() {
      document.querySelectorAll('.square').forEach(el => {
        el.classList.remove('selected', 'highlight');
      });
    }
    
    function updateStatus() {
      let status = '';
      if (game.in_checkmate()) {
        status = `Game Over - ${game.turn() === 'w' ? 'Black' : 'White'} wins!`;
      } else if (game.in_draw()) {
        status = 'Game Over - Draw';
      } else {
        status = (game.turn() === 'w' ? 'White' : 'Black') + ' to move';
        if (game.in_check()) status += ' (Check)';
      }
      statusEl.textContent = status;
      
      if (game.turn() === 'w') statusEl.style.color = 'var(--accent-cyan)';
      else statusEl.style.color = 'var(--accent-purple)';
    }
    
    // Simple AI Logic
    const pieceValues = { p: 10, n: 30, b: 30, r: 50, q: 90, k: 900 };
    
    function evaluateBoard(g) {
      let score = 0;
      const board = g.board();
      for (let r = 0; r < 8; r++) {
        for (let c = 0; c < 8; c++) {
          const piece = board[r][c];
          if (piece) {
            const val = pieceValues[piece.type];
            score += piece.color === 'w' ? val : -val;
          }
        }
      }
      return score;
    }
    
    function minimax(g, depth, alpha, beta, isMaximizingPlayer) {
      if (depth === 0 || g.game_over()) {
        return evaluateBoard(g);
      }
      
      const moves = g.moves();
      if (isMaximizingPlayer) {
        let bestVal = -Infinity;
        for (let move of moves) {
          g.move(move);
          bestVal = Math.max(bestVal, minimax(g, depth - 1, alpha, beta, !isMaximizingPlayer));
          g.undo();
          alpha = Math.max(alpha, bestVal);
          if (beta <= alpha) break;
        }
        return bestVal;
      } else {
        let bestVal = Infinity;
        for (let move of moves) {
          g.move(move);
          bestVal = Math.min(bestVal, minimax(g, depth - 1, alpha, beta, !isMaximizingPlayer));
          g.undo();
          beta = Math.min(beta, bestVal);
          if (beta <= alpha) break;
        }
        return bestVal;
      }
    }
    
    function getBestMove(g, depth) {
      const moves = g.moves();
      let bestMove = null;
      let bestValue = Infinity; // AI plays Black (Minimizing)
      
      // Shuffle moves to add randomness to equal evaluations
      moves.sort(() => Math.random() - 0.5);
      
      for (let move of moves) {
        g.move(move);
        const boardValue = minimax(g, depth - 1, -Infinity, Infinity, true);
        g.undo();
        
        if (boardValue < bestValue) {
          bestValue = boardValue;
          bestMove = move;
        }
      }
      return bestMove || moves[0];
    }
    
    function makeAIMove() {
      if (game.game_over()) return;
      
      const depthStr = difficultySelect.value;
      const depth = parseInt(depthStr);
      let move;
      
      if (depth === 1) {
        // Random
        const moves = game.moves();
        move = moves[Math.floor(Math.random() * moves.length)];
      } else {
        // Minimax
        statusEl.textContent = "AI is thinking...";
        setTimeout(() => {
          move = getBestMove(game, depth);
          game.move(move);
          renderBoard();
          isPlayerTurn = true;
          updateStatus();
        }, 50); // slight delay to allow UI to update "thinking..." status
        return;
      }
      
      game.move(move);
      renderBoard();
      isPlayerTurn = true;
      updateStatus();
    }
    
    btnRestart.addEventListener('click', () => {
      game.reset();
      selectedSquare = null;
      isPlayerTurn = true;
      renderBoard();
    });
    
    // Init
    renderBoard();
    
  </script>

</GameLayout>
