---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools, groupedTools } from '../data/tools';

const categories = ['All', 'Productivity', 'Developer', 'Encoding', 'Design', 'Generators', 'Text'];
---

<BaseLayout title="DevToolKit — Premium Online Developer Tools" description="Lightning-fast, privacy-first developer tools running entirely client-side. JSON Formatter, Base64 Encoder, Color Converter, Word Counter & more.">
  <!-- Hero with Animated Background -->
  <section class="hero">
    <div class="hero-mesh"></div>
    <div class="hero-particles"></div>
    <div class="container hero-content">
      <!-- Hero Statistics Badge -->
      <div class="badge-glow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
        100% Client-Side Processing
      </div>

      <h1>
        The Ultimate <span class="gradient-text">Developer Suite</span>
      </h1>
      <p class="hero-subtitle">
        A premium collection of high-performance tools designed for speed and privacy. No server uploads. No tracking. Just instant results right in your browser.
      </p>
      
      <!-- Universal Search Component -->
      <div class="search-wrapper" style="margin-bottom: 2rem;">
        <input type="text" class="search-input" id="hero-search" placeholder="Search tools (e.g. JSON, PDF, Encode)..." autocomplete="off" aria-label="Search tools">
        <svg class="search-icon-svg" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <span class="search-shortcut-hint">/</span>
      </div>
    </div>
  </section>

  <!-- Pinned / Favorite Tools Section -->
  <section class="container recent-pinned-section" id="favorites-section">
    <h3 style="font-size: 1.8rem; margin-bottom: 0.8rem; color: var(--text-primary);">Quick Access</h3>
    <div class="recent-pinned-grid" id="favorites-grid"></div>
  </section>

  <!-- Main Tools Grid & Category Filters -->
  <section class="container tools-grid-section" id="tools-section">
    <!-- Category Filter Pills -->
    <div class="categories-filter" id="categories-filter">
      {categories.map((cat, i) => (
        <button class={`filter-pill ${i === 0 ? 'active' : ''}`} data-category={cat}>{cat}</button>
      ))}
    </div>

    <!-- Grid List -->
    <div class="tools-grid" id="tools-grid">
      {tools.map((tool) => (
        <div class="tool-card-container" data-title={tool.name} data-desc={tool.description} data-category={tool.category}>
          <ToolCard {...tool} />
        </div>
      ))}
    </div>
    
    <!-- Empty State for Search -->
    <div id="no-results" class="editor-empty-state" style="display: none;">
      <svg viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      <p style="font-size: 1.6rem; color: var(--text-primary);">No tools found matching your search.</p>
      <p>Try a different keyword or check the categories above.</p>
      <button class="btn btn-secondary" style="margin-top: 1.6rem;" onclick="document.getElementById('hero-search').value=''; document.getElementById('hero-search').dispatchEvent(new Event('input'));">Clear Search</button>
    </div>
  </section>

  <!-- Why DevToolKit Bento Benefits Grid -->
  <section class="container" style="padding: 6rem 0 10rem;">
    <h2 style="font-size: 3.2rem; text-align: center; margin-bottom: 1.6rem;">Designed For Developers</h2>
    <p style="text-align: center; color: var(--text-secondary); max-width: 600px; margin: 0 auto 5.6rem;">All calculations occur 100% locally inside your browser process space. Your information remains completely safe.</p>
    
    <div style="display: flex; flex-wrap: wrap; gap: 2.4rem; justify-content: center;">
      <div class="glass-card" style="padding: 3.2rem; flex: 1 1 280px; max-width: 400px; text-align: center;">
        <div class="tool-icon-wrapper" style="margin: 0 auto 2rem; color: var(--accent-purple); background: var(--accent-purple-glow); border-color: rgba(139, 92, 246, 0.2);">
          <svg viewBox="0 0 24 24" style="width: 2.4rem; height: 2.4rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        </div>
        <h3 style="font-size: 2rem; margin-bottom: 1rem;">Privacy Guarantee</h3>
        <p style="font-size: 1.45rem; line-height: 1.6;">No data ever transfers to external hosts. Secure client execution prevents data logging.</p>
      </div>

      <div class="glass-card" style="padding: 3.2rem; flex: 1 1 280px; max-width: 400px; text-align: center;">
        <div class="tool-icon-wrapper" style="margin: 0 auto 2rem; color: var(--accent-emerald); background: var(--accent-emerald-glow); border-color: rgba(16, 185, 129, 0.2);">
          <svg viewBox="0 0 24 24" style="width: 2.4rem; height: 2.4rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 style="font-size: 2rem; margin-bottom: 1rem;">Zero Delays</h3>
        <p style="font-size: 1.45rem; line-height: 1.6;">Build structures compiled to run on lightweight modern browser sandboxes instantly.</p>
      </div>

      <div class="glass-card" style="padding: 3.2rem; flex: 1 1 280px; max-width: 400px; text-align: center;">
        <div class="tool-icon-wrapper" style="margin: 0 auto 2rem; color: var(--accent-cyan); background: var(--accent-cyan-glow); border-color: rgba(6, 182, 212, 0.2);">
          <svg viewBox="0 0 24 24" style="width: 2.4rem; height: 2.4rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        </div>
        <h3 style="font-size: 2rem; margin-bottom: 1rem;">Command Palette</h3>
        <p style="font-size: 1.45rem; line-height: 1.6;">Press "/" or "Ctrl+K" at any point to search or navigate to specific utilities instantly.</p>
      </div>
    </div>
  </section>

  <div id="valid-tools-data" data-urls={JSON.stringify(tools.map(t => t.url))} style="display:none;" aria-hidden="true"></div>

  <script is:inline>
    // Universal filter and search logic
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('hero-search');
      const filterPills = document.querySelectorAll('.filter-pill');
      const cardContainers = document.querySelectorAll('.tool-card-container');
      const noResults = document.getElementById('no-results');
      const toolsGrid = document.getElementById('tools-grid');
      
      let activeCategory = 'All';
      let searchQuery = '';

      function filterCards() {
        let hasVisible = false;
        cardContainers.forEach(container => {
          const title = container.getAttribute('data-title').toLowerCase();
          const desc = container.getAttribute('data-desc').toLowerCase();
          const category = container.getAttribute('data-category');

          const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery);
          const matchesCategory = activeCategory === 'All' || category === activeCategory;

          if (matchesSearch && matchesCategory) {
            container.style.display = 'block';
            hasVisible = true;
          } else {
            container.style.display = 'none';
          }
        });
        
        if (hasVisible) {
          toolsGrid.style.display = 'grid';
          noResults.style.display = 'none';
        } else {
          toolsGrid.style.display = 'none';
          noResults.style.display = 'flex';
        }
      }

      // Input listening
      searchInput?.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase();
        filterCards();
      });

      // Categories Pill clicking
      filterPills.forEach(pill => {
        pill.addEventListener('click', () => {
          filterPills.forEach(p => p.classList.remove('active'));
          pill.classList.add('active');
          activeCategory = pill.getAttribute('data-category');
          filterCards();
        });
      });

      // Page '/' focus shortcut
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement !== searchInput) {
          const activeEl = document.activeElement;
          const isInput = activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA');
          if (!isInput) {
            e.preventDefault();
            searchInput?.focus();
          }
        }
      });

      // Helper to get valid tools
      function getValidTools() {
        const dataEl = document.getElementById('valid-tools-data');
        if (!dataEl) return [];
        try {
          return JSON.parse(dataEl.getAttribute('data-urls') || '[]');
        } catch (e) {
          return [];
        }
      }

      // Local storage Favorites loader
      function loadFavorites() {
        const favSec = document.getElementById('favorites-section');
        const favGrid = document.getElementById('favorites-grid');
        if (!favSec || !favGrid) return;

        try {
          const rawFavorites = JSON.parse(localStorage.getItem('favoriteTools') || '[]');
          const validUrls = getValidTools();
          
          // Filter out invalid tools
          const favorites = rawFavorites.filter(tool => validUrls.includes(tool.url));
          
          // Update local storage if we removed any invalid tools
          if (favorites.length !== rawFavorites.length) {
            localStorage.setItem('favoriteTools', JSON.stringify(favorites));
          }

          if (favorites.length === 0) {
            favSec.classList.remove('has-items');
            return;
          }

          favSec.classList.add('has-items');
          favGrid.innerHTML = '';
          favorites.forEach(tool => {
            const a = document.createElement('a');
            a.className = 'recent-tool-card';
            a.href = tool.url;
            a.innerHTML = `
              <svg fill="currentColor" viewBox="0 0 24 24" style="color: var(--accent-rose);"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
              <div class="recent-tool-info">
                <h4>${tool.name}</h4>
                <p>${tool.category}</p>
              </div>
              <span class="tool-hotkey">➔</span>
            `;
            favGrid.appendChild(a);
          });
        } catch (e) {
          console.error(e);
        }
      }

      loadFavorites();
    });
  </script>
</BaseLayout>
