---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service" description="DevToolKit Terms of Service.">
  <main class="container static-page-container">
    <div style="text-align: center; margin-bottom: 4rem;">
      <h1>Terms of <span class="gradient-text">Service</span></h1>
      <p style="font-size: 1.8rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto;">
        Last Updated: July 2026
      </p>
    </div>

    <div class="glass-panel" style="padding: 4rem; margin-bottom: 4rem;">
      <h2>1. Acceptance of Terms</h2>
      <p>
        By accessing and using DevToolKit, you accept and agree to be bound by the terms and provisions of this agreement.
      </p>
    </div>

    <div class="glass-panel" style="padding: 4rem; margin-bottom: 4rem;">
      <h2>2. Disclaimer of Warranties</h2>
      <p>
        DevToolKit is provided "as is" and "as available" without any warranties of any kind. While we strive for accuracy in our developer tools, we do not guarantee that the tools are error-free.
      </p>
      <ul>
        <li>You use these tools at your own risk.</li>
        <li>We are not responsible for any data loss, code corruption, or system issues resulting from the use of our tools.</li>
      </ul>
    </div>

    <div class="glass-panel" style="padding: 4rem;">
      <h2>3. Acceptable Use</h2>
      <p>
        You agree not to use DevToolKit for any unlawful purpose or in any way that might harm, damage, or disparage any other party.
      </p>
      <p style="margin-top: 2.4rem;">
        <a href="/" class="btn btn-primary">Back to Tools</a>
      </p>
    </div>
  </main>
</BaseLayout>
