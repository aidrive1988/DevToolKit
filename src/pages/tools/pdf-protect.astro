---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="PDF Protect — Encrypt & Password Protect PDF | DevToolKit" description="Secure your PDF files with passwords and 128-bit encryption. 100% client-side processing for maximum privacy." toolName="PDF Protect" category="Productivity">

  <div class="tool-container">
    <!-- Upload Zone -->
    <div class="drop-zone" id="drop-zone">
      <div class="drop-zone-content">
        <span style="font-size:4.8rem;display:block;margin-bottom:1rem;">🔒</span>
        <p style="font-size:1.8rem;font-weight:600;color:var(--text-primary);margin-bottom:0.6rem;">Drop a PDF file here or click to upload</p>
        <p style="font-size:1.4rem;color:var(--text-muted);">Select a single PDF file to encrypt and password-protect</p>
      </div>
      <input type="file" id="file-input" accept=".pdf,application/pdf" style="display:none;" />
    </div>

    <!-- Active File Info -->
    <div id="file-info" style="display:none;margin-top:2rem;padding:1.6rem;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-md);">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div style="display:flex;align-items:center;gap:1.2rem;">
          <span style="font-size:2.4rem;">📄</span>
          <div>
            <div id="active-filename" style="font-size:1.5rem;font-weight:600;color:var(--text-primary);">filename.pdf</div>
            <div id="active-filemeta" style="font-size:1.3rem;color:var(--text-muted);">0 KB</div>
          </div>
        </div>
        <button class="btn btn-secondary btn-sm" id="btn-change-file">🔄 Change File</button>
      </div>
    </div>

    <!-- Protection Settings -->
    <div id="protect-settings" style="display:none;margin:2rem 0;padding:1.6rem;background:var(--bg-input);border-radius:var(--radius-md);border:1px solid var(--border-color);">
      <h3 style="font-size:1.5rem;margin-bottom:1.6rem;color:var(--text-primary);">Encryption Settings</h3>
      
      <div style="margin-bottom:1.6rem;">
        <label style="font-size:1.4rem;font-weight:600;color:var(--text-primary);display:block;margin-bottom:0.6rem;">User Password (Required to Open)</label>
        <input type="password" id="user-password" placeholder="Enter password to require for viewing" style="width:100%;padding:1rem 1.2rem;background:var(--bg-primary);border:1px solid var(--border-color);border-radius:var(--radius-sm);color:var(--text-primary);font-size:1.5rem;" />
        <p style="font-size:1.2rem;color:var(--text-muted);margin-top:0.6rem;">Anyone opening the PDF will need to type this password to view its contents.</p>
      </div>

      <div style="margin-bottom:1.6rem;">
        <label style="font-size:1.4rem;font-weight:600;color:var(--text-primary);display:block;margin-bottom:0.6rem;">Owner Password (Optional)</label>
        <input type="password" id="owner-password" placeholder="Enter owner password" style="width:100%;padding:1rem 1.2rem;background:var(--bg-primary);border:1px solid var(--border-color);border-radius:var(--radius-sm);color:var(--text-primary);font-size:1.5rem;" />
        <p style="font-size:1.2rem;color:var(--text-muted);margin-top:0.6rem;">Used to protect permissions. If omitted, it will default to the User Password.</p>
      </div>

      <div>
        <label style="font-size:1.3rem;color:var(--text-secondary);display:block;margin-bottom:0.4rem;">Output Filename</label>
        <input type="text" id="output-filename" value="protected-document" placeholder="protected-document" style="padding:0.8rem 1.2rem;background:var(--bg-primary);border:1px solid var(--border-color);border-radius:var(--radius-sm);color:var(--text-primary);font-size:1.4rem;width:100%;max-width:300px;" />
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="tool-actions" style="margin-top:2rem;">
      <button class="btn btn-primary" id="btn-protect" disabled>🔒 Encrypt PDF</button>
    </div>

    <div class="tool-error" id="protect-error"></div>

    <!-- Progress Bar -->
    <div id="progress-container" style="display:none;margin-top:1.6rem;">
      <div style="display:flex;justify-content:space-between;margin-bottom:0.4rem;">
        <span style="font-size:1.3rem;color:var(--text-secondary);" id="progress-label">Encrypting document...</span>
      </div>
      <div style="height:6px;background:var(--bg-input);border-radius:3px;overflow:hidden;">
        <div id="progress-bar" style="height:100%;width:100%;background:var(--gradient-primary);border-radius:3px;animation:pulse 1.5s infinite;"></div>
      </div>
    </div>
  </div>

  <div class="info-section" slot="how-to-use">
    <h2>How to Protect a PDF</h2>
    <ol class="steps-list">
      <li><strong>Upload a PDF</strong> by dragging and dropping it, or clicking the upload area.</li>
      <li><strong>Enter a User Password</strong>. This is the password anyone will need to type to open and view the document.</li>
      <li><strong>(Optional) Enter an Owner Password</strong> to manage permissions.</li>
      <li>Click <strong>Encrypt PDF</strong> to secure the file. Your new protected PDF will download automatically.</li>
    </ol>
  </div>

  <div class="info-section" slot="faq">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-item">
      <p class="faq-question">Is the encryption secure?</p>
      <p class="faq-answer">Yes, this tool uses standard 128-bit RC4 encryption (Algorithm 2 & 3 from the PDF specification), which is fully supported by all modern PDF viewers including Chrome, Acrobat, and Mac Preview.</p>
    </div>
    <div class="faq-item">
      <p class="faq-question">Does my file get uploaded to a server?</p>
      <p class="faq-answer">No! Just like our other tools, the encryption happens entirely locally in your web browser. Your document is never uploaded anywhere, ensuring complete privacy.</p>
    </div>
    <div class="faq-item">
      <p class="faq-question">Can I protect a document that's already encrypted?</p>
      <p class="faq-answer">Currently, you must first decrypt/unlock a document using your existing PDF software before you can apply a new password using this tool.</p>
    </div>
  </div>
</ToolLayout>

<style>
  .drop-zone {
    border: 2px dashed var(--border-color);
    border-radius: var(--radius-lg);
    padding: 4rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: var(--transition-normal);
    background: var(--bg-input);
  }
  .drop-zone:hover, .drop-zone.drag-over {
    border-color: var(--accent-purple);
    background: rgba(139, 92, 246, 0.05);
  }
  @keyframes pulse {
    0% { opacity: 0.6; }
    50% { opacity: 1; }
    100% { opacity: 0.6; }
  }
  .btn-sm { padding: 0.6rem 1.2rem; font-size: 1.3rem; }
</style>

<script>
  import { encryptPDF } from '@pdfsmaller/pdf-encrypt-lite';

  let activePdf = null; // { file, name, size, arrayBuffer }
  
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const fileInfoEl = document.getElementById('file-info');
  const settingsEl = document.getElementById('protect-settings');
  const btnProtect = document.getElementById('btn-protect');
  const errorEl = document.getElementById('protect-error');
  const progressContainer = document.getElementById('progress-container');
  const userPasswordInput = document.getElementById('user-password');
  const ownerPasswordInput = document.getElementById('owner-password');

  // Drop zone events
  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    if (e.dataTransfer.files.length > 0) {
      handleFile(e.dataTransfer.files[0]);
    }
  });
  
  fileInput.addEventListener('change', () => { 
    if (fileInput.files.length > 0) {
      handleFile(fileInput.files[0]); 
    }
    fileInput.value = ''; 
  });

  document.getElementById('btn-change-file').addEventListener('click', () => {
    activePdf = null;
    dropZone.style.display = 'block';
    fileInfoEl.style.display = 'none';
    settingsEl.style.display = 'none';
    btnProtect.disabled = true;
    hideError();
    userPasswordInput.value = '';
    ownerPasswordInput.value = '';
  });

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.style.display = 'block';
  }

  function hideError() {
    errorEl.style.display = 'none';
  }

  async function handleFile(file) {
    if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
      try {
        hideError();
        const arrayBuffer = await file.arrayBuffer();
        
        activePdf = { file, name: file.name, size: file.size, arrayBuffer };
        
        // Update UI
        dropZone.style.display = 'none';
        fileInfoEl.style.display = 'block';
        settingsEl.style.display = 'block';
        btnProtect.disabled = false;
        
        document.getElementById('active-filename').textContent = file.name;
        document.getElementById('active-filemeta').textContent = `${formatSize(file.size)}`;
        
        // Suggest filename
        const baseName = file.name.replace(/\.pdf$/i, '');
        document.getElementById('output-filename').value = `${baseName}-protected`;
        
        // Focus password input
        userPasswordInput.focus();
        
      } catch (err) {
        showError(`Could not read "${file.name}": ${err.message}`);
      }
    } else {
      showError('Please select a valid PDF file.');
    }
  }

  function formatSize(bytes) {
    if (bytes > 1048576) return (bytes / 1048576).toFixed(1) + ' MB';
    return Math.round(bytes / 1024) + ' KB';
  }

  // Encrypt / Protect
  btnProtect.addEventListener('click', async () => {
    if (!activePdf) return;
    hideError();
    
    const userPwd = userPasswordInput.value;
    if (!userPwd) {
      showError('A user password is required to encrypt the PDF.');
      return;
    }
    
    let ownerPwd = ownerPasswordInput.value;
    if (!ownerPwd) {
      ownerPwd = userPwd; // Default owner password to user password if omitted
    }

    btnProtect.disabled = true;
    btnProtect.textContent = '⏳ Encrypting...';
    progressContainer.style.display = '';

    try {
      const pdfBytes = new Uint8Array(activePdf.arrayBuffer);
      
      // Perform the encryption
      const encryptedBytes = await encryptPDF(pdfBytes, userPwd, ownerPwd);
      
      // Save and download
      const blob = new Blob([encryptedBytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);

      const filenameInput = document.getElementById('output-filename');
      let filename = (filenameInput.value || 'protected-document').trim();
      if (!filename.toLowerCase().endsWith('.pdf')) filename += '.pdf';

      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);

    } catch (err) {
      showError(`Error encrypting PDF: ${err.message}`);
      console.error(err);
    } finally {
      btnProtect.disabled = false;
      btnProtect.textContent = '🔒 Encrypt PDF';
      progressContainer.style.display = 'none';
    }
  });
</script>
