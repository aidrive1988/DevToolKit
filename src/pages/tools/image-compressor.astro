---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="Image Compressor & Resizer" description="Compress and resize images directly in your browser. Reduce file size without uploading to any server." toolName="Image Compressor" category="Media">
  
  <div class="workspace-toolbar">
    <div class="toolbar-actions">
      <label class="btn btn-primary" style="cursor: pointer; margin: 0;">
        <span>📤 Select Image</span>
        <input type="file" id="file-upload" accept="image/*" style="display: none;" />
      </label>
    </div>
    <div class="toolbar-actions">
      <button class="btn btn-danger" id="btn-clear" title="Clear loaded image">
        <span>🗑 Clear</span>
      </button>
    </div>
  </div>

  <div class="workspace-grid" style="grid-template-columns: 1fr 1fr;">
    <!-- Original Image -->
    <div class="editor-container">
      <div class="editor-header-bar">
        <span class="editor-title">Original Image</span>
      </div>
      <div class="editor-row" style="background: var(--bg-primary); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem;">
        
        <div class="dropzone-overlay" id="drop-overlay" style="display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px dashed var(--border-color); border-radius: var(--radius-md); width: 100%; height: 300px;">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--text-secondary); margin-bottom: 1rem;"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <p style="color: var(--text-secondary); font-size: 1.4rem;">Drag & drop an image here</p>
        </div>

        <div id="original-preview" style="display: none; width: 100%; text-align: center;">
          <img id="orig-img" style="max-width: 100%; max-height: 300px; border-radius: var(--radius-sm); border: 1px solid var(--border-color);" />
          <div id="orig-info" style="margin-top: 1rem; font-size: 1.2rem; color: var(--text-secondary);"></div>
        </div>

      </div>
    </div>

    <!-- Compressed Output Settings -->
    <div class="editor-container">
      <div class="editor-header-bar">
        <span class="editor-title">Compression Settings</span>
      </div>
      <div class="editor-row" style="padding: 2rem; background: var(--bg-primary);">
        
        <div style="display: flex; flex-direction: column; gap: 1.6rem; max-width: 400px;">
          
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label for="max-size" style="font-weight: 600; font-size: 1.3rem;">Target Max Size (MB)</label>
            <input type="number" id="max-size" class="editor-textarea" value="1.0" step="0.1" min="0.1" style="height: 40px; padding: 0.5rem;" />
          </div>

          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label for="max-width" style="font-weight: 600; font-size: 1.3rem;">Max Width / Height (px)</label>
            <input type="number" id="max-width" class="editor-textarea" value="1920" step="100" min="100" style="height: 40px; padding: 0.5rem;" />
          </div>

          <button class="btn btn-primary" id="btn-compress" style="width: 100%; justify-content: center; font-size: 1.4rem;" disabled>
            Compress Image
          </button>
          
          <!-- Result section -->
          <div id="result-section" style="display: none; flex-direction: column; gap: 1rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-color);">
            <div style="color: var(--accent-green); font-weight: bold; font-size: 1.4rem;">Compression Complete!</div>
            <div id="result-info" style="font-size: 1.2rem; color: var(--text-primary);"></div>
            <button class="btn btn-secondary" id="btn-download" style="width: 100%; justify-content: center; font-size: 1.4rem;">
              Download Compressed Image
            </button>
          </div>

        </div>

      </div>
    </div>
  </div>

  <script>
    import imageCompression from 'browser-image-compression';

    const fileUpload = document.getElementById('file-upload') as HTMLInputElement;
    const dropOverlay = document.getElementById('drop-overlay') as HTMLDivElement;
    const originalPreview = document.getElementById('original-preview') as HTMLDivElement;
    const origImg = document.getElementById('orig-img') as HTMLImageElement;
    const origInfo = document.getElementById('orig-info') as HTMLDivElement;
    
    const btnClear = document.getElementById('btn-clear');
    const btnCompress = document.getElementById('btn-compress') as HTMLButtonElement;
    const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;
    
    const maxSizeInput = document.getElementById('max-size') as HTMLInputElement;
    const maxWidthInput = document.getElementById('max-width') as HTMLInputElement;
    
    const resultSection = document.getElementById('result-section') as HTMLDivElement;
    const resultInfo = document.getElementById('result-info') as HTMLDivElement;

    let currentFile: File | null = null;
    let compressedBlob: Blob | null = null;
    let compressedExt = '';

    function formatBytes(bytes: number) {
      if (bytes === 0) return '0 Bytes';
      const k = 1024, sizes = ['Bytes', 'KB', 'MB', 'GB'], i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }

    async function loadImage(file: File) {
      if (!file.type.startsWith('image/')) {
        if (window.showToast) window.showToast('Please upload a valid image file.', 'error');
        return;
      }

      currentFile = file;
      const url = URL.createObjectURL(file);
      
      const imgElement = new Image();
      imgElement.onload = () => {
        dropOverlay.style.display = 'none';
        originalPreview.style.display = 'block';
        origImg.src = url;
        origInfo.textContent = `${file.name} - ${formatBytes(file.size)} - ${imgElement.width}x${imgElement.height}px`;
        btnCompress.disabled = false;
        resultSection.style.display = 'none';
      };
      imgElement.src = url;
    }

    fileUpload.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file) loadImage(file);
    });

    // Drag and Drop
    const container = document.querySelector('.workspace-grid') as HTMLElement;
    container.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropOverlay.style.borderColor = 'var(--accent-purple)';
    });
    container.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dropOverlay.style.borderColor = 'var(--border-color)';
    });
    container.addEventListener('drop', (e) => {
      e.preventDefault();
      dropOverlay.style.borderColor = 'var(--border-color)';
      const file = e.dataTransfer?.files?.[0];
      if (file) loadImage(file);
    });

    btnClear?.addEventListener('click', () => {
      currentFile = null;
      compressedBlob = null;
      fileUpload.value = '';
      dropOverlay.style.display = 'flex';
      originalPreview.style.display = 'none';
      resultSection.style.display = 'none';
      btnCompress.disabled = true;
    });

    btnCompress?.addEventListener('click', async () => {
      if (!currentFile) return;
      
      btnCompress.disabled = true;
      btnCompress.textContent = 'Compressing...';
      
      try {
        const options = {
          maxSizeMB: parseFloat(maxSizeInput.value),
          maxWidthOrHeight: parseInt(maxWidthInput.value, 10),
          useWebWorker: true
        };

        const compressedFile = await imageCompression(currentFile, options);
        compressedBlob = compressedFile;
        compressedExt = compressedFile.name.split('.').pop() || 'jpg';
        
        resultInfo.innerHTML = `
          <div><strong>New Size:</strong> ${formatBytes(compressedFile.size)}</div>
          <div><strong>Reduction:</strong> ${((1 - (compressedFile.size / currentFile.size)) * 100).toFixed(1)}% smaller</div>
        `;
        resultSection.style.display = 'flex';
        
        if (window.showToast) window.showToast(`Compressed successfully!`);
      } catch (error) {
        console.error('Compression error:', error);
        if (window.showToast) window.showToast('Compression failed.', 'error');
      } finally {
        btnCompress.disabled = false;
        btnCompress.textContent = 'Compress Image';
      }
    });
    
    btnDownload?.addEventListener('click', () => {
      if (!compressedBlob || !currentFile) return;
      
      const origName = currentFile.name.substring(0, currentFile.name.lastIndexOf('.'));
      const url = URL.createObjectURL(compressedBlob);
      const link = document.createElement('a');
      link.download = `${origName || 'compressed'}_min.${compressedExt}`;
      link.href = url;
      link.click();
    });

  </script>
</ToolLayout>
