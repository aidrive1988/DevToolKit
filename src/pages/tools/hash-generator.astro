---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="Hash Generator — MD5, SHA-1, SHA-256, SHA-512" description="Generate secure cryptographic hashes (MD5, SHA-1, SHA-256, SHA-512) instantly from text or files. 100% client-side." toolName="Hash Generator" category="Text">
  
  <div class="workspace-toolbar">
    <div class="toolbar-actions">
      <label class="btn btn-secondary" style="cursor: pointer; margin: 0;" title="Upload File to Hash">
        <span>📤 Hash File</span>
        <input type="file" id="file-upload" style="display: none;" />
      </label>
      <button class="btn btn-danger" id="btn-clear" title="Clear all text fields">
        <span>🗑 Clear</span>
      </button>
    </div>
  </div>

  <div class="workspace-grid">
    <!-- Input Workspace -->
    <div class="editor-container" id="input-container">
      <div class="editor-header-bar">
        <span class="editor-title">Input Data</span>
        <button class="toolbar-btn" id="btn-paste" title="Paste from clipboard">
          <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
        </button>
      </div>
      <div class="editor-row">
        <div class="editor-main-area">
          <textarea id="hash-input" class="editor-textarea" placeholder="Enter text to generate hashes..." autocomplete="off"></textarea>
          <!-- Drag & Drop Overlay -->
          <div class="dropzone-overlay" id="drop-overlay">
            <svg viewBox="0 0 24 24"><path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
            <p>Drop file here to hash</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Output Workspace (List of Hashes) -->
    <div class="editor-container" style="display: flex; flex-direction: column; gap: 1rem; background: transparent; border: none; padding: 0;">
      <!-- MD5 -->
      <div class="hash-result-card">
        <div class="hash-header">
          <strong>MD5</strong>
          <button class="btn btn-secondary btn-sm copy-hash" data-target="out-md5">Copy</button>
        </div>
        <textarea id="out-md5" class="editor-textarea" style="height: 60px; min-height: 60px; resize: none; background: var(--bg-primary);" readonly></textarea>
      </div>
      <!-- SHA-1 -->
      <div class="hash-result-card">
        <div class="hash-header">
          <strong>SHA-1</strong>
          <button class="btn btn-secondary btn-sm copy-hash" data-target="out-sha1">Copy</button>
        </div>
        <textarea id="out-sha1" class="editor-textarea" style="height: 60px; min-height: 60px; resize: none; background: var(--bg-primary);" readonly></textarea>
      </div>
      <!-- SHA-256 -->
      <div class="hash-result-card">
        <div class="hash-header">
          <strong>SHA-256</strong>
          <button class="btn btn-secondary btn-sm copy-hash" data-target="out-sha256">Copy</button>
        </div>
        <textarea id="out-sha256" class="editor-textarea" style="height: 80px; min-height: 80px; resize: none; background: var(--bg-primary);" readonly></textarea>
      </div>
      <!-- SHA-512 -->
      <div class="hash-result-card">
        <div class="hash-header">
          <strong>SHA-512</strong>
          <button class="btn btn-secondary btn-sm copy-hash" data-target="out-sha512">Copy</button>
        </div>
        <textarea id="out-sha512" class="editor-textarea" style="height: 110px; min-height: 110px; resize: none; background: var(--bg-primary);" readonly></textarea>
      </div>
    </div>
  </div>

  <style>
    .hash-result-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      padding: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }
    .hash-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .hash-header strong {
      color: var(--text-primary);
      font-size: 1.4rem;
      letter-spacing: 0.05em;
    }
    .btn-sm {
      padding: 0.4rem 1rem;
      font-size: 1.2rem;
    }
  </style>

  <script>
    import CryptoJS from 'crypto-js';

    const input = document.getElementById('hash-input') as HTMLTextAreaElement;
    const outMd5 = document.getElementById('out-md5') as HTMLTextAreaElement;
    const outSha1 = document.getElementById('out-sha1') as HTMLTextAreaElement;
    const outSha256 = document.getElementById('out-sha256') as HTMLTextAreaElement;
    const outSha512 = document.getElementById('out-sha512') as HTMLTextAreaElement;
    const btnClear = document.getElementById('btn-clear');
    const btnPaste = document.getElementById('btn-paste');
    const fileUpload = document.getElementById('file-upload') as HTMLInputElement;
    const dropOverlay = document.getElementById('drop-overlay');
    const copyBtns = document.querySelectorAll('.copy-hash');

    let processingFile = false;

    // Core Hashing function
    function generateHashes(text: string) {
      if (!text) {
        outMd5.value = '';
        outSha1.value = '';
        outSha256.value = '';
        outSha512.value = '';
        return;
      }
      
      try {
        outMd5.value = CryptoJS.MD5(text).toString();
        outSha1.value = CryptoJS.SHA1(text).toString();
        outSha256.value = CryptoJS.SHA256(text).toString();
        outSha512.value = CryptoJS.SHA512(text).toString();
      } catch (e) {
        console.error('Hashing error:', e);
      }
    }

    input.addEventListener('input', () => {
      if (!processingFile) {
        generateHashes(input.value);
      }
    });

    btnClear?.addEventListener('click', () => {
      input.value = '';
      generateHashes('');
      input.focus();
    });

    btnPaste?.addEventListener('click', async () => {
      try {
        const text = await navigator.clipboard.readText();
        input.value = text;
        generateHashes(text);
      } catch (err) {
        if (window.showToast) window.showToast('Failed to read clipboard', 'error');
      }
    });

    copyBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const targetId = (e.currentTarget as HTMLElement).getAttribute('data-target');
        if (!targetId) return;
        const targetEl = document.getElementById(targetId) as HTMLTextAreaElement;
        
        if (targetEl.value) {
          navigator.clipboard.writeText(targetEl.value);
          const origText = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => btn.textContent = origText, 2000);
          if (window.showToast) window.showToast('Hash copied to clipboard!');
        }
      });
    });

    // File Handling
    function handleFile(file: File) {
      if (!file) return;
      processingFile = true;
      input.value = `[File: ${file.name}] - Reading...`;
      
      const reader = new FileReader();
      
      // For large files we really should use progressive hashing or WebCrypto, but for simplicity
      // and strings/small files, CryptoJS WordArray is used.
      reader.onload = (e) => {
        const result = e.target?.result as string;
        input.value = `[File: ${file.name}] - Hashed successfully.`;
        generateHashes(result);
        processingFile = false;
      };
      
      reader.onerror = () => {
        input.value = '';
        processingFile = false;
        if (window.showToast) window.showToast('Failed to read file', 'error');
      };

      // Read as text (for small files it works fine, for binary we'd need ArrayBuffer -> WordArray)
      reader.readAsText(file);
    }

    fileUpload?.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file) handleFile(file);
      // Reset so same file can be selected again
      (e.target as HTMLInputElement).value = '';
    });

    // Drag and Drop
    input.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropOverlay?.classList.add('active');
    });
    
    input.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dropOverlay?.classList.remove('active');
    });
    
    input.addEventListener('drop', (e) => {
      e.preventDefault();
      dropOverlay?.classList.remove('active');
      const file = e.dataTransfer?.files?.[0];
      if (file) handleFile(file);
    });

  </script>

  <Fragment slot="how-to-use">
    <h3>About Hash Generator</h3>
    <p>A cryptographic hash function maps data of arbitrary size to a fixed-size string (the hash value). It is a one-way function, meaning it's practically impossible to invert the hash to get the original data.</p>
    <ul>
      <li><strong>MD5:</strong> Widely used but considered cryptographically broken. Good for checksums.</li>
      <li><strong>SHA-1:</strong> Historically popular, but vulnerable to collision attacks.</li>
      <li><strong>SHA-256:</strong> Part of the SHA-2 family. Highly secure and widely used in blockchains and SSL certificates.</li>
      <li><strong>SHA-512:</strong> Similar to SHA-256 but operates on 64-bit words, producing a longer, more secure hash.</li>
    </ul>
    <p>This tool runs entirely in your browser using <code>crypto-js</code>. Your data never leaves your device.</p>
  </Fragment>
</ToolLayout>
