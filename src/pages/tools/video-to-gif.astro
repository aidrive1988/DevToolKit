---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="Video to GIF Converter" description="Convert local videos into animated GIFs entirely in your browser using FFmpeg WebAssembly. No files leave your device." toolName="Video to GIF Converter" category="Media">
  
  <div class="workspace-toolbar">
    <div class="toolbar-actions">
      <label class="btn btn-primary" style="cursor: pointer; margin: 0;">
        <span>📤 Select Video</span>
        <input type="file" id="file-upload" accept="video/*" style="display: none;" />
      </label>
    </div>
    <div class="toolbar-actions">
      <button class="btn btn-danger" id="btn-clear" title="Clear loaded video">
        <span>🗑 Clear</span>
      </button>
    </div>
  </div>

  <!-- WASM Model Disclaimer -->
  <div class="info-alert" style="margin-bottom: 2rem; background: rgba(56, 189, 248, 0.1); border: 1px solid rgba(56, 189, 248, 0.3); padding: 1.2rem; border-radius: var(--radius-md); display: flex; align-items: start; gap: 1rem;">
    <svg viewBox="0 0 24 24" width="24" height="24" style="color: #38bdf8; flex-shrink: 0; margin-top: 2px;" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <div>
      <h4 style="margin: 0 0 0.5rem 0; color: #38bdf8; font-size: 1.4rem;">WebAssembly First-Time Load</h4>
      <p style="margin: 0; font-size: 1.2rem; color: var(--text-primary); line-height: 1.5;">This tool uses a powerful video engine (FFmpeg) compiled for the browser. The first time you use it, it will download ~30MB of engine files. <strong>Your videos are never uploaded to any server.</strong></p>
    </div>
  </div>

  <div class="workspace-grid" style="grid-template-columns: 1.2fr 0.8fr; gap: 2rem;">
    <!-- Original Video -->
    <div class="editor-container" style="border: none; background: transparent; box-shadow: none;">
      <div class="editor-header-bar" style="border-radius: var(--radius-md) var(--radius-md) 0 0; background: linear-gradient(to right, var(--bg-card), var(--bg-primary));">
        <span class="editor-title" style="font-size: 1.4rem;">Original Video</span>
      </div>
      <div class="editor-row" style="background: var(--bg-card); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; border-radius: 0 0 var(--radius-md) var(--radius-md); border: 1px solid var(--border-color); border-top: none; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);">
        
        <div class="dropzone-overlay" id="drop-overlay" style="display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px dashed var(--accent-purple); border-radius: var(--radius-md); width: 100%; height: 350px; background: linear-gradient(135deg, rgba(168, 85, 247, 0.05), rgba(236, 72, 153, 0.05)); cursor: pointer; transition: all 0.3s ease;">
          <div style="background: var(--bg-primary); padding: 1.5rem; border-radius: 50%; box-shadow: 0 8px 16px rgba(0,0,0,0.1); margin-bottom: 1.5rem;">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="url(#purple-gradient)" stroke-width="2"><defs><linearGradient id="purple-gradient" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#a855f7" /><stop offset="100%" stop-color="#ec4899" /></linearGradient></defs><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </div>
          <p style="color: var(--text-primary); font-size: 1.6rem; font-weight: 600; margin: 0 0 0.5rem 0;">Drag & drop your video</p>
          <p style="color: var(--text-secondary); font-size: 1.2rem; margin: 0;">or click "Select Video" above</p>
          <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center;">
            <span style="background: rgba(168, 85, 247, 0.15); color: #c084fc; padding: 0.2rem 0.8rem; border-radius: 12px; font-size: 1rem; font-weight: 600;">MP4</span>
            <span style="background: rgba(168, 85, 247, 0.15); color: #c084fc; padding: 0.2rem 0.8rem; border-radius: 12px; font-size: 1rem; font-weight: 600;">WebM</span>
            <span style="background: rgba(168, 85, 247, 0.15); color: #c084fc; padding: 0.2rem 0.8rem; border-radius: 12px; font-size: 1rem; font-weight: 600;">MOV</span>
            <span style="background: rgba(168, 85, 247, 0.15); color: #c084fc; padding: 0.2rem 0.8rem; border-radius: 12px; font-size: 1rem; font-weight: 600;">AVI</span>
            <span style="background: rgba(168, 85, 247, 0.15); color: #c084fc; padding: 0.2rem 0.8rem; border-radius: 12px; font-size: 1rem; font-weight: 600;">MKV</span>
          </div>
        </div>

        <div id="original-preview" style="display: none; width: 100%; text-align: center;">
          <video id="orig-video" controls autoplay muted playsinline loop style="width: 100%; max-height: 400px; border-radius: var(--radius-md); box-shadow: 0 8px 24px rgba(0,0,0,0.4); background: var(--bg-primary);"></video>
          
          <div id="orig-info" style="margin-top: 1.5rem; font-size: 1.3rem; font-weight: 500; color: var(--text-primary);"></div>
          
          <div style="margin-top: 1rem; padding: 1rem; background: rgba(234, 179, 8, 0.1); border-left: 4px solid #eab308; border-radius: 4px; display: flex; align-items: start; gap: 0.8rem; text-align: left;">
            <span style="font-size: 1.4rem;">💡</span>
            <p style="margin: 0; font-size: 1.15rem; color: var(--text-secondary); line-height: 1.4;">If the video preview is black but you hear audio, your browser does not support the video's codec (e.g. HEVC). Don't worry, <strong>the GIF conversion will still work perfectly!</strong></p>
          </div>
        </div>

      </div>
    </div>

    <!-- Output Settings -->
    <div class="editor-container" style="border: none; background: transparent; box-shadow: none;">
      <div class="editor-header-bar" style="border-radius: var(--radius-md) var(--radius-md) 0 0; background: linear-gradient(to right, var(--bg-card), var(--bg-primary));">
        <span class="editor-title" style="font-size: 1.4rem;">Export Settings</span>
      </div>
      <div class="editor-row" style="padding: 2.5rem; background: var(--bg-card); border-radius: 0 0 var(--radius-md) var(--radius-md); border: 1px solid var(--border-color); border-top: none; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);">
        
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <div style="display: flex; flex-direction: column; gap: 0.8rem;">
            <label for="fps-select" style="font-weight: 600; font-size: 1.3rem; color: var(--text-primary);">Framerate (FPS)</label>
            <select id="fps-select" style="height: 44px; padding: 0.6rem 1rem; font-size: 1.3rem; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius-sm); color: var(--text-primary); cursor: pointer; transition: border-color 0.2s;">
              <option value="5">5 FPS (Smallest File, Choppy)</option>
              <option value="10" selected>10 FPS (Recommended Balance)</option>
              <option value="15">15 FPS (Smooth, Larger File)</option>
              <option value="30">30 FPS (Very Large File)</option>
            </select>
          </div>

          <div style="display: flex; flex-direction: column; gap: 0.8rem;">
            <label for="width-select" style="font-weight: 600; font-size: 1.3rem; color: var(--text-primary);">Resolution (Max Width)</label>
            <select id="width-select" style="height: 44px; padding: 0.6rem 1rem; font-size: 1.3rem; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius-sm); color: var(--text-primary); cursor: pointer; transition: border-color 0.2s;">
              <option value="320">320px (Fastest)</option>
              <option value="480" selected>480px (Recommended)</option>
              <option value="640">640px (High Quality)</option>
              <option value="-1">Original Resolution</option>
            </select>
          </div>

          <button class="btn btn-primary" id="btn-convert" style="width: 100%; justify-content: center; font-size: 1.5rem; font-weight: 600; padding: 1.2rem; background: linear-gradient(135deg, var(--accent-purple), #ec4899); color: #ffffff !important; border: none; box-shadow: 0 4px 15px rgba(168, 85, 247, 0.4); margin-top: 1rem; transition: transform 0.2s, box-shadow 0.2s;" disabled>
            ✨ Convert to GIF
          </button>
          
          <!-- Loading State -->
          <div id="loading-state" style="display: none; flex-direction: column; align-items: center; margin-top: 2rem; text-align: center; background: rgba(168, 85, 247, 0.05); padding: 2rem; border-radius: var(--radius-md); border: 1px solid rgba(168, 85, 247, 0.2);">
            <svg class="spinner" viewBox="0 0 50 50" style="width: 40px; height: 40px; animation: spin 1s linear infinite; margin-bottom: 1rem;"><circle cx="25" cy="25" r="20" fill="none" stroke="url(#purple-gradient)" stroke-width="4" stroke-dasharray="80" stroke-dashoffset="60" stroke-linecap="round"></circle></svg>
            <div id="progress-text" style="color: var(--text-primary); font-size: 1.4rem; font-weight: 500;">Loading FFmpeg engine...</div>
            <div id="ffmpeg-log" style="margin-top: 1rem; font-size: 1.1rem; color: var(--text-secondary); max-width: 100%; word-wrap: break-word; text-align: center;"></div>
          </div>

          <!-- Result section -->
          <div id="result-section" style="display: none; flex-direction: column; gap: 1.5rem; margin-top: 1rem; padding: 1.5rem; border: 1px solid rgba(34, 197, 94, 0.3); background: rgba(34, 197, 94, 0.05); border-radius: var(--radius-md);">
            <div style="color: #22c55e; font-weight: 700; font-size: 1.5rem; text-align: center; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"></path></svg>
              Conversion Complete!
            </div>
            
            <div style="background: var(--bg-primary); padding: 1rem; border-radius: var(--radius-sm); border: 1px solid var(--border-color);">
              <img id="result-gif" style="max-width: 100%; max-height: 250px; object-fit: contain; margin: 0 auto; display: block;" />
            </div>
            
            <div id="result-info" style="font-size: 1.3rem; font-weight: 600; color: var(--text-primary); text-align: center;"></div>
            
            <button class="btn btn-primary" id="btn-download" style="width: 100%; justify-content: center; font-size: 1.4rem; padding: 1rem; background: #22c55e; border: none; box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3); transition: transform 0.2s, box-shadow 0.2s;">
              <span style="font-size: 1.6rem; margin-right: 0.5rem;">📥</span> Download GIF
            </button>
          </div>

        </div>

      </div>
    </div>
  </div>

  <style>
    @keyframes spin { 100% { transform: rotate(360deg); } }
  </style>

  <script is:inline src="/ffmpeg.js"></script>
  <script>
    const { FFmpeg } = window.FFmpegWASM;

    async function fetchFile(file) {
      return new Uint8Array(await file.arrayBuffer());
    }

    async function toBlobURL(url, mimeType) {
      const resp = await fetch(url);
      const buf = await resp.arrayBuffer();
      const blob = new Blob([buf], { type: mimeType });
      return URL.createObjectURL(blob);
    }

    const fileUpload = document.getElementById('file-upload') as HTMLInputElement;
    const dropOverlay = document.getElementById('drop-overlay') as HTMLDivElement;
    const originalPreview = document.getElementById('original-preview') as HTMLDivElement;
    const origVideo = document.getElementById('orig-video') as HTMLVideoElement;
    const origInfo = document.getElementById('orig-info') as HTMLDivElement;
    
    const btnClear = document.getElementById('btn-clear');
    const btnConvert = document.getElementById('btn-convert') as HTMLButtonElement;
    const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;
    
    const fpsSelect = document.getElementById('fps-select') as HTMLSelectElement;
    const widthSelect = document.getElementById('width-select') as HTMLSelectElement;
    
    const loadingState = document.getElementById('loading-state') as HTMLDivElement;
    const progressText = document.getElementById('progress-text') as HTMLDivElement;
    const resultSection = document.getElementById('result-section') as HTMLDivElement;
    const resultGif = document.getElementById('result-img') as HTMLImageElement;
    const resultInfo = document.getElementById('result-info') as HTMLDivElement;

    let currentFile: File | null = null;
    let resultBlob: Blob | null = null;
    let ffmpeg: FFmpeg | null = null;

    function formatBytes(bytes: number) {
      if (bytes === 0) return '0 Bytes';
      const k = 1024, sizes = ['Bytes', 'KB', 'MB', 'GB'], i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }

    function loadVideo(file: File) {
      if (!file.type.startsWith('video/')) {
        if (window.showToast) window.showToast('Please upload a valid video file.', 'error');
        return;
      }

      currentFile = file;
      const url = URL.createObjectURL(file);
      
      dropOverlay.style.display = 'none';
      originalPreview.style.display = 'block';
      origVideo.src = url;
      origVideo.load();
      origVideo.play().catch(e => console.log('Autoplay prevented', e));
      
      origInfo.textContent = `${file.name} - ${formatBytes(file.size)}`;
      
      btnConvert.disabled = false;
      resultSection.style.display = 'none';
      loadingState.style.display = 'none';
    }

    fileUpload.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file) loadVideo(file);
    });

    // Drag and Drop
    const container = document.querySelector('.workspace-grid') as HTMLElement;
    container.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropOverlay.style.borderColor = 'var(--accent-purple)';
    });
    container.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dropOverlay.style.borderColor = 'var(--border-color)';
    });
    container.addEventListener('drop', (e) => {
      e.preventDefault();
      dropOverlay.style.borderColor = 'var(--border-color)';
      const file = e.dataTransfer?.files?.[0];
      if (file) loadVideo(file);
    });

    btnClear?.addEventListener('click', () => {
      currentFile = null;
      resultBlob = null;
      fileUpload.value = '';
      dropOverlay.style.display = 'flex';
      originalPreview.style.display = 'none';
      resultSection.style.display = 'none';
      loadingState.style.display = 'none';
      btnConvert.disabled = true;
      if (origVideo.src) {
        URL.revokeObjectURL(origVideo.src);
        origVideo.src = '';
      }
    });

    async function initFFmpeg() {
      if (ffmpeg) return ffmpeg;

      ffmpeg = new FFmpeg();
      
      ffmpeg.on('log', ({ message }) => {
        console.log('[FFmpeg]', message);
        const logEl = document.getElementById('ffmpeg-log');
        if (logEl) logEl.textContent = message;
      });
      
      ffmpeg.on('progress', ({ progress, time }) => {
        progressText.textContent = `Processing: ${Math.round(progress * 100)}%`;
      });

      // Load core via unpkg to avoid local hosting complexities with wasm files in Astro
      const baseURL = 'https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd';
      
      await ffmpeg.load({
        coreURL: await toBlobURL(`${baseURL}/ffmpeg-core.js`, 'text/javascript'),
        wasmURL: await toBlobURL(`${baseURL}/ffmpeg-core.wasm`, 'application/wasm')
      });
      
      return ffmpeg;
    }

    btnConvert?.addEventListener('click', async () => {
      if (!currentFile) return;
      
      btnConvert.disabled = true;
      btnConvert.style.display = 'none';
      loadingState.style.display = 'flex';
      progressText.textContent = 'Loading FFmpeg engine... (First time takes longer)';
      
      try {
        const ff = await initFFmpeg();
        
        progressText.textContent = 'Reading file into memory...';
        await ff.writeFile('input_video.mp4', await fetchFile(currentFile));

        progressText.textContent = 'Starting conversion...';
        
        const fps = fpsSelect.value;
        const width = widthSelect.value;
        const scaleFilter = width === '-1' ? '' : `,scale=${width}:-1`;
        
        // Optimize GIF creation using a palette
        // 1. Generate palette
        let code = await ff.exec(['-i', 'input_video.mp4', '-vf', `fps=${fps}${scaleFilter}:flags=lanczos,palettegen`, 'palette.png']);
        if (code !== 0) throw new Error(`FFmpeg palettegen failed with code ${code}`);
        
        // 2. Output gif
        code = await ff.exec(['-i', 'input_video.mp4', '-i', 'palette.png', '-filter_complex', `fps=${fps}${scaleFilter}:flags=lanczos[x];[x][1:v]paletteuse`, 'output.gif']);
        if (code !== 0) throw new Error(`FFmpeg gif encoding failed with code ${code}`);
        
        progressText.textContent = 'Finishing up...';

        const data = await ff.readFile('output.gif');
        resultBlob = new Blob([data.buffer as ArrayBuffer], { type: 'image/gif' });
        
        const url = URL.createObjectURL(resultBlob);
        
        const resultImg = document.getElementById('result-gif') as HTMLImageElement;
        resultImg.src = url;
        resultInfo.textContent = `Size: ${formatBytes(resultBlob.size)}`;
        
        loadingState.style.display = 'none';
        resultSection.style.display = 'flex';
        
        if (window.showToast) window.showToast(`Converted to GIF successfully!`);
      } catch (error) {
        console.error('Conversion error:', error);
        loadingState.style.display = 'none';
        const msg = typeof error === 'string' ? error : (error instanceof Error ? error.message : JSON.stringify(error) || 'Unknown error');
        if (window.showToast) window.showToast('Conversion failed: ' + msg, 'error');
        alert('Conversion failed: ' + msg + '\nSee console for FFmpeg logs.');
        btnConvert.style.display = 'flex';
        btnConvert.disabled = false;
      }
    });
    
    btnDownload?.addEventListener('click', () => {
      if (!resultBlob || !currentFile) return;
      
      const origName = currentFile.name.substring(0, currentFile.name.lastIndexOf('.'));
      const url = URL.createObjectURL(resultBlob);
      const link = document.createElement('a');
      link.download = `${origName || 'video'}.gif`;
      link.href = url;
      link.click();
    });

  </script>
</ToolLayout>
