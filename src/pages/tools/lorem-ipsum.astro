---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="Lorem Ipsum Generator — Custom Placeholder Text Suite" description="Generate placeholder text instantly. Customize paragraphs, sentences, or word limits with range sliders." toolName="Lorem Ipsum Generator" category="Text">
  
  <div class="workspace-toolbar">
    <div class="toolbar-actions" style="display:flex; align-items:center; gap:1.2rem;">
      <button class="btn btn-primary" id="btn-generate">
        <span>✨ Generate</span>
      </button>
      <label style="display: flex; align-items: center; gap: 0.6rem; font-size: 1.3rem; cursor: pointer;">
        <input type="checkbox" id="check-live" checked style="accent-color: var(--accent-purple);" />
        <span>Live Preview</span>
      </label>
    </div>

    <div class="toolbar-actions">
      <button class="btn btn-secondary" id="btn-download" title="Download output text file">
        <span>📥 Download</span>
      </button>
      <button class="btn btn-danger" id="btn-clear" title="Clear generated output">
        <span>🗑 Clear</span>
      </button>
    </div>
  </div>

  <!-- Main Grid Workspace -->
  <div class="workspace-grid">
    <!-- Left Workspace: Configuration Controls -->
    <div class="editor-container" style="padding:2.4rem; gap:2.4rem;">
      <h3 style="font-size:1.8rem; border-bottom:1px solid var(--border-color); padding-bottom:1rem;">Configuration</h3>

      <!-- Format Type -->
      <div style="display:flex; flex-direction:column; gap:0.6rem;">
        <label style="font-size:1.3rem; font-weight:600; color:var(--text-secondary);">Generation Type</label>
        <select id="lorem-type" style="padding:1rem 1.4rem; background:var(--bg-input); border:1px solid var(--border-color); border-radius:var(--radius-sm); color:var(--text-primary); font-size:1.4rem; outline:none; cursor:pointer;">
          <option value="paragraphs">Paragraphs</option>
          <option value="sentences">Sentences</option>
          <option value="words">Words</option>
        </select>
      </div>

      <!-- Quantity Slider -->
      <div class="slider-group">
        <div class="slider-header-lbl">
          <span>Quantity</span>
          <span><strong id="slider-val-lbl">3</strong> <span id="slider-unit-lbl">Paragraphs</span></span>
        </div>
        <div class="slider-input-wrapper">
          <input type="range" id="lorem-slider" min="1" max="20" value="3" />
        </div>
      </div>

      <!-- Options -->
      <div style="display:flex; flex-direction:column; gap:1.2rem;">
        <label style="font-size:1.3rem; font-weight:600; color:var(--text-secondary);">Opening Options</label>
        <label style="display:flex; align-items:center; gap:0.8rem; cursor:pointer; font-size:1.4rem;">
          <input type="checkbox" id="lorem-classic" checked style="accent-color:var(--accent-purple); width:16px; height:16px;" />
          <span>Start with "Lorem ipsum dolor..."</span>
        </label>
      </div>
    </div>

    <!-- Right Workspace: Output Panel -->
    <div class="editor-container">
      <div class="editor-header-bar">
        <span class="editor-title">Generated Text</span>
        <button class="toolbar-btn" id="btn-copy" title="Copy to clipboard">
          <svg viewBox="0 0 24 24"><path d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m-2 4h5m0 0l-2-2m2 2l-2 2"></path></svg>
        </button>
      </div>

      <!-- Result Pre block -->
      <div class="editor-main-area" style="flex-grow: 1; position:relative;">
        <div id="processing-loader" style="display:none; position:absolute; inset:0; background:rgba(var(--bg-card),0.8); z-index:30; align-items:center; justify-content:center; flex-direction:column; gap:1.2rem;">
          <div class="spinner" style="width:3rem; height:3rem; border-top-color:var(--accent-purple);"></div>
          <p style="font-size:1.3rem; color:var(--text-secondary);">Generating placeholder text...</p>
        </div>

        <pre class="editor-output-pre" id="lorem-output-text" style="height:320px; overflow-y:auto; white-space:pre-wrap;"><span class="editor-empty-state"><svg viewBox="0 0 24 24"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>Generated text will load here...</span></pre>
      </div>

      <!-- Footer stats -->
      <div class="editor-footer-status">
        <span id="stat-paras">0 Paragraphs</span>
        <span id="stat-words">0 Words</span>
        <span id="stat-chars">0 Chars</span>
      </div>
    </div>
  </div>

  <div class="info-section" slot="how-to-use">
    <h2>How to Use the Lorem Ipsum Generator</h2>
    <ol class="steps-list">
      <li>Choose your generation format (Paragraphs, Sentences, or Words) inside the Configuration panel.</li>
      <li>Move the range slider to select the quantity. If **Live Preview** is checked, the layout will update instantly.</li>
      <li>Click **Copy** or **Download** to extract the formatted dummy text into your project.</li>
    </ol>
  </div>

  <div class="info-section" slot="faq">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-item">
      <p class="faq-question">What is Lorem Ipsum?</p>
      <p class="faq-answer">Lorem Ipsum is dummy placeholder text. By mimicking standard spelling structures and character distributions, it allows layout designers and developers to review visual typography properties without being distracted by readable copy.</p>
    </div>
    <div class="faq-item">
      <p class="faq-question">Where does this dummy text originate?</p>
      <p class="faq-answer">The vocabulary words originate from Cicero's book, *De Finibus Bonorum et Malorum* written in 45 BC. The layout was scrambled and altered during the 1500s to form the classic typesetting standard.</p>
    </div>
  </div>
</ToolLayout>

<script>
  const SENTENCES = [
    "Lorem ipsum dolor sit amet, consectetur adipiscing elit.",
    "Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
    "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.",
    "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore.",
    "Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia.",
    "Nulla facilisi morbi tempus iaculis urna id volutpat lacus.",
    "Amet consectetur adipiscing elit pellentesque habitant morbi tristique senectus.",
    "Viverra accumsan in nisl nisi scelerisque eu ultrices vitae.",
    "Eget nulla facilisi etiam dignissim diam quis enim lobortis.",
    "Faucibus interdum posuere lorem ipsum dolor sit amet consectetur.",
    "Pellentesque eu tincidunt tortor aliquam nulla facilisi cras fermentum.",
    "Mauris augue neque gravida in fermentum et sollicitudin ac.",
    "Egestas integer eget aliquet nibh praesent tristique magna sit.",
    "Volutpat consequat mauris nunc congue nisi vitae suscipit tellus.",
    "Feugiat in ante metus dictum at tempor commodo ullamcorper.",
    "Adipiscing commodo elit at imperdiet dui accumsan sit amet.",
    "Erat pellentesque adipiscing commodo elit at imperdiet dui accumsan.",
    "Cursus euismod quis viverra nibh cras pulvinar mattis nunc.",
    "Amet venenatis urna cursus eget nunc scelerisque viverra mauris.",
    "Ornare suspendisse sed nisi lacus sed viverra tellus in.",
    "Sit amet facilisis magna etiam tempor orci eu lobortis.",
    "Nisl pretium fusce id velit ut tortor pretium viverra.",
    "Sem fringilla ut morbi tincidunt augue interdum velit euismod.",
    "Tristique nulla aliquet enim tortor at auctor urna nunc.",
    "Vel facilisis volutpat est velit egestas dui id ornare.",
    "Pretium quam vulputate dignissim suspendisse in est ante in.",
    "Ultrices in iaculis nunc sed augue lacus viverra vitae.",
    "Congue eu consequat ac felis donec et odio pellentesque.",
    "Mattis rhoncus urna neque viverra justo nec ultrices dui.",
    "Imperdiet massa tincidunt nunc pulvinar sapien et ligula ullamcorper.",
    "Habitant morbi tristique senectus et netus et malesuada fames.",
    "Turpis egestas maecenas pharetra convallis posuere morbi leo urna.",
    "Tincidunt lobortis feugiat vivamus at augue eget arcu dictum.",
    "Id porta nibh venenatis cras sed felis eget velit.",
    "Sed risus pretium quam vulputate dignissim suspendisse in est.",
    "Bibendum at varius vel pharetra vel turpis nunc eget.",
    "Amet tellus cras adipiscing enim eu turpis egestas pretium.",
    "Facilisi nullam vehicula ipsum a arcu cursus vitae congue.",
    "Non odio euismod lacinia at quis risus sed vulputate.",
    "Ultrices gravida dictum fusce ut placerat orci nulla pellentesque.",
    "Viverra vitae congue eu consequat ac felis donec et.",
    "Pharetra magna ac placerat vestibulum lectus mauris ultrices eros.",
    "Nisi est sit amet facilisis magna etiam tempor orci.",
    "Massa id neque aliquam vestibulum morbi blandit cursus risus.",
    "Elementum tempus egestas sed sed risus pretium quam vulputate.",
    "Vitae turpis massa sed elementum tempus egestas sed sed.",
    "Eget arcu dictum varius duis at consectetur lorem donec.",
    "Sagittis scelerisque purus semper eget duis at tellus at.",
    "Tortor posuere ac ut consequat semper viverra nam libero.",
    "Augue ut lectus arcu bibendum at varius vel pharetra."
  ];

  const WORDS = SENTENCES.join(' ').replace(/[.,]/g, '').toLowerCase().split(/\s+/);

  function getRandom(arr: any[]) { return arr[Math.floor(Math.random() * arr.length)]; }

  function shuffle(arr: any[]) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function generateParagraph() {
    const count = 4 + Math.floor(Math.random() * 5);
    return shuffle(SENTENCES).slice(0, count).join(' ');
  }

  // Selectors
  const typeSelect = document.getElementById('lorem-type') as HTMLSelectElement;
  const slider = document.getElementById('lorem-slider') as HTMLInputElement;
  const sliderVal = document.getElementById('slider-val-lbl');
  const sliderUnit = document.getElementById('slider-unit-lbl');
  const checkClassic = document.getElementById('lorem-classic') as HTMLInputElement;
  const checkLive = document.getElementById('check-live') as HTMLInputElement;

  const outputText = document.getElementById('lorem-output-text');
  const loaderEl = document.getElementById('processing-loader');

  const statParas = document.getElementById('stat-paras');
  const statWords = document.getElementById('stat-words');
  const statChars = document.getElementById('stat-chars');

  // Load last session configurations
  document.addEventListener('DOMContentLoaded', () => {
    const savedType = localStorage.getItem('lorem_type') || 'paragraphs';
    const savedVal = localStorage.getItem('lorem_val') || '3';
    
    if (typeSelect) typeSelect.value = savedType;
    updateSliderLimits();
    if (slider) slider.value = savedVal;
    updateSliderLabels();

    if (checkLive?.checked) {
      generateText(true);
    }
  });

  typeSelect?.addEventListener('change', () => {
    localStorage.setItem('lorem_type', typeSelect.value);
    updateSliderLimits();
    updateSliderLabels();
    if (checkLive?.checked) generateText(true);
  });

  slider?.addEventListener('input', () => {
    updateSliderLabels();
    localStorage.setItem('lorem_val', slider.value);
    if (checkLive?.checked) generateText(true); // run silently
  });

  checkClassic?.addEventListener('change', () => {
    if (checkLive?.checked) generateText(true);
  });

  function updateSliderLimits() {
    if (!slider) return;
    const type = typeSelect.value;
    if (type === 'paragraphs') {
      slider.min = '1';
      slider.max = '20';
      if (parseInt(slider.value) > 20) slider.value = '3';
    } else if (type === 'sentences') {
      slider.min = '1';
      slider.max = '100';
      if (parseInt(slider.value) > 100) slider.value = '15';
    } else {
      slider.min = '5';
      slider.max = '500';
      if (parseInt(slider.value) > 500) slider.value = '50';
    }
  }

  function updateSliderLabels() {
    if (!slider || !sliderVal || !sliderUnit) return;
    sliderVal.textContent = slider.value;
    const type = typeSelect.value;
    sliderUnit.textContent = type.charAt(0).toUpperCase() + type.slice(1);
  }

  function generateText(silent = false) {
    const count = parseInt(slider.value) || 1;
    const type = typeSelect.value;
    const classic = checkClassic.checked;

    if (silent) {
      const result = computeLorem(count, type, classic);
      displayOutput(result);
    } else {
      if (!loaderEl) return;
      loaderEl.style.display = 'flex';
      
      setTimeout(() => {
        const result = computeLorem(count, type, classic);
        displayOutput(result);
        if (loaderEl) loaderEl.style.display = 'none';
        window.showToast('Generated placeholder text!', 'success');
      }, 250);
    }
  }

  function computeLorem(count: number, type: string, classic: boolean): string {
    let result = '';

    if (type === 'paragraphs') {
      const paras = [];
      for (let i = 0; i < count; i++) paras.push(generateParagraph());
      if (classic && paras.length > 0) {
        paras[0] = SENTENCES[0] + ' ' + paras[0];
      }
      result = paras.join('\n\n');
    } else if (type === 'sentences') {
      const sents = shuffle(SENTENCES).slice(0, Math.min(count, SENTENCES.length));
      while (sents.length < count) sents.push(getRandom(SENTENCES));
      if (classic) sents[0] = SENTENCES[0];
      result = sents.join(' ');
    } else {
      const words = [];
      for (let i = 0; i < count; i++) words.push(getRandom(WORDS));
      if (classic && words.length >= 2) { words[0] = 'lorem'; words[1] = 'ipsum'; }
      result = words.join(' ');
    }

    return result;
  }

  function displayOutput(result: string) {
    if (!outputText) return;
    const escaped = result.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    outputText.innerHTML = escaped;

    // Update statistics
    if (statParas) statParas.textContent = `${result.split('\n\n').filter(p => p.trim()).length} Paragraphs`;
    if (statWords) statWords.textContent = `${result.split(/\s+/).filter(w => w).length} Words`;
    if (statChars) statChars.textContent = `${result.length} Chars`;
  }

  // Trigger Manual generate
  document.getElementById('btn-generate')?.addEventListener('click', () => {
    generateText(false);
  });

  // Clear output
  document.getElementById('btn-clear')?.addEventListener('click', () => {
    displayOutput('');
    window.showToast('Cleared generated outputs', 'info');
  });

  // Copy output
  document.getElementById('btn-copy')?.addEventListener('click', () => {
    const text = outputText?.innerText || '';
    if (!text || text.includes('Generated text will load')) {
      window.showToast('Nothing to copy!', 'error');
      return;
    }
    navigator.clipboard.writeText(text).then(() => {
      window.showToast('Copied dummy text!', 'success');
    });
  });

  // Download File
  document.getElementById('btn-download')?.addEventListener('click', () => {
    const text = outputText?.innerText || '';
    if (!text || text.includes('Generated text will load')) {
      window.showToast('No output to download!', 'error');
      return;
    }
    const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = 'placeholder-lorem.txt';
    link.click();
    window.showToast('Downloaded text file!', 'success');
  });
</script>
