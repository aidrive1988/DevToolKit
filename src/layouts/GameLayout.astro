---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  gameName: string;
  category: string;
  canonicalURL?: string;
}

const { title, description, gameName, category, canonicalURL } = Astro.props;
const siteURL = 'https://devtoolkit.pages.dev';
const gameUrl = Astro.url.pathname;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": gameName,
  "applicationCategory": "GameApplication",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "url": canonicalURL || new URL(Astro.url.pathname, siteURL).href,
  "description": description
};
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL} sidebarType="games">
  <Header />
  
  <main class="container workspace-container">
    <!-- Breadcrumbs -->
    <nav class="workspace-breadcrumb" aria-label="Breadcrumb">
      <a href="/games">Games Hub</a>
      <span class="sep">›</span>
      <span>{gameName}</span>
    </nav>

    <!-- Game header -->
    <div class="workspace-title-section">
      <div style="display: flex; align-items: center; gap: 1.6rem; flex-wrap: wrap;">
        <h1>{gameName}</h1>
      </div>
      <p>{description}</p>
    </div>

    <!-- Active Game Content Slot -->
    <div class="tool-content-wrapper" style="animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards; opacity: 0; display: flex; flex-direction: column; align-items: center; gap: 2rem;">
      <slot />
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</BaseLayout>
