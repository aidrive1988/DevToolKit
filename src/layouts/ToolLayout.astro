---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCategoryColor } from '../data/tools';

interface Props {
  title: string;
  description: string;
  toolName: string;
  category: string;
  canonicalURL?: string;
}

const { title, description, toolName, category, canonicalURL } = Astro.props;
const catColor = getCategoryColor(category);
const siteURL = 'https://devtoolkit.pages.dev';
const toolUrl = Astro.url.pathname;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": toolName,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "url": canonicalURL || new URL(Astro.url.pathname, siteURL).href,
  "description": description
};
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL}>
  <Header />
  
  <main class="container workspace-container">
    <!-- Breadcrumbs -->
    <nav class="workspace-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Tools</a>
      <span class="sep">/</span>
      <span style={`color: ${catColor}; font-weight: 500;`}>{category}</span>
      <span class="sep">/</span>
      <span>{toolName}</span>
    </nav>

    <!-- Tool header with Pinned/Favorite controls -->
    <div class="workspace-title-section" style={`--cat-color: ${catColor};`}>
      <div style="display: flex; align-items: center; gap: 1.6rem; flex-wrap: wrap;">
        <h1>{toolName}</h1>
        <button class="pin-toggle-btn" id="tool-favorite-btn" aria-label="Pin this tool" title="Pin tool to homepage">
          <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
        </button>
      </div>
      <p>{description}</p>
    </div>

    <!-- Active Tool Content Slot -->
    <div class="tool-content-wrapper" style="animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards; opacity: 0;">
      <slot />
    </div>

    <!-- Instructions Slot -->
    <div class="tool-content-wrapper" style="animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards; opacity: 0;">
      <slot name="how-to-use" />
    </div>

    <!-- FAQ Slot with Accordions -->
    <div class="tool-content-wrapper" style="animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards; opacity: 0;">
      <slot name="faq" />
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <script is:inline define:vars={{ toolName, description, toolUrl, category }}>
    // Add this tool to recent tools list on load
    (function recordRecent() {
      try {
        const recent = JSON.parse(localStorage.getItem('recentTools') || '[]');
        // Remove duplicate if it already exists
        const filtered = recent.filter(item => item.url !== toolUrl);
        // Add to front of queue
        filtered.unshift({ name: toolName, desc: description, url: toolUrl, category });
        // Cap at 4 items
        if (filtered.length > 4) filtered.pop();
        localStorage.setItem('recentTools', JSON.stringify(filtered));
      } catch (e) {
        console.error('Error saving recent tool', e);
      }
    })();

    // Favorite/Pin functionality on tool pages
    const favBtn = document.getElementById('tool-favorite-btn');
    if (favBtn) {
      function checkFavState() {
        try {
          const favorites = JSON.parse(localStorage.getItem('favoriteTools') || '[]');
          const isFav = favorites.some(item => item.url === toolUrl);
          if (isFav) {
            favBtn.classList.add('pinned');
            const svgPath = favBtn.querySelector('svg');
            if (svgPath) {
              svgPath.setAttribute('fill', 'currentColor');
            }
          } else {
            favBtn.classList.remove('pinned');
            const svgPath = favBtn.querySelector('svg');
            if (svgPath) {
              svgPath.setAttribute('fill', 'none');
            }
          }
        } catch (e) {
          console.error(e);
        }
      }

      checkFavState();

      favBtn.addEventListener('click', () => {
        try {
          const favorites = JSON.parse(localStorage.getItem('favoriteTools') || '[]');
          const isFav = favorites.some(item => item.url === toolUrl);
          let updated = [];
          if (isFav) {
            updated = favorites.filter(item => item.url !== toolUrl);
            window.showToast('Unpinned from favorites', 'info');
          } else {
            favorites.push({ name: toolName, desc: description, url: toolUrl, category });
            updated = favorites;
            window.showToast('Pinned to favorites!', 'success');
          }
          localStorage.setItem('favoriteTools', JSON.stringify(updated));
          checkFavState();
        } catch (e) {
          console.error(e);
        }
      });
    }

    // Accordion expand/collapse controller for FAQs
    document.addEventListener('DOMContentLoaded', () => {
      const faqItems = document.querySelectorAll('.faq-item');
      faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');
        const answer = item.querySelector('.faq-answer');
        
        // Add rotate arrow icon if not present
        if (question && !question.querySelector('svg')) {
          question.innerHTML += `
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          `;
        }

        question?.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          
          // Close all FAQ items
          faqItems.forEach(i => {
            i.classList.remove('open');
            const a = i.querySelector('.faq-answer');
            if (a) a.style.maxHeight = null;
          });

          // Toggle current item
          if (!isOpen) {
            item.classList.add('open');
            if (answer) {
              answer.style.maxHeight = answer.scrollHeight + 'px';
            }
          }
        });
      });
    });
  </script>
</BaseLayout>
